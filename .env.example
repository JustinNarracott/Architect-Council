
# Architecture Council — Environment Variables
# Copy to .env and add your API keys

# Standards Analyst (GPT-4.1) + DA Chair (GPT-4.1)
OPENAI_API_KEY=sk-your-openai-key

# Enterprise Architect (Claude Sonnet 4)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DX Analyst (Perplexity Sonar Pro) + Security Analyst (Perplexity Sonar Pro)
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Google API key not required — Enterprise Architect migrated to Claude Sonnet 4
# GOOGLE_API_KEY=your-google-api-key

# Ollama not required — Security Analyst migrated to Perplexity Sonar Pro
# OLLAMA_API_BASE=http://localhost:11434

# Path to your local repositories directory (used by codebase analysis feature)
# Docker mounts this as /repos inside the container
# Example (Windows): REPOS_PATH=C:/Users/yourname/Projects
# Example (Linux/Mac): REPOS_PATH=/home/yourname/projects
REPOS_PATH=./repos

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS — restrict to your frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:3011

# API authentication — leave blank to disable in dev
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ARCHITECT_API_KEY=
