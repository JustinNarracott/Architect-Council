# Architecture Council — Environment Variables
# Copy to .env and add your API keys

# Standards Analyst (GPT-4.1) + DA Chair (GPT-5.1)
OPENAI_API_KEY=sk-your-openai-key

# Enterprise Architect (Claude Sonnet 4)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# (Google API key no longer required — Security moved to local Ollama)
# GOOGLE_API_KEY=your-google-api-key

# DX Analyst (Perplexity Sonar Pro)
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Security Analyst — Ollama local model (Qwen3 Coder 30B)
# Set to your Ollama server address (default: http://localhost:11434)
OLLAMA_API_BASE=http://localhost:11434

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true
